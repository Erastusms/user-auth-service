// ============================================================
//  Prisma Schema — user_multi_app
//  Maps ke database PostgreSQL yang sudah dibuat sebelumnya.
//  Karena tabel sudah ada, gunakan: prisma db pull (introspect)
//  atau prisma migrate --create-only untuk generate migration.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── ENUM Types ─────────────────────────────────────────────────

enum provider_type {
  email
  google
  github
  microsoft
  clerk
  apple
  facebook
  twitter
}

enum session_status {
  active
  expired
  revoked
}

enum mfa_type {
  totp
  sms
  email_otp
  webauthn
}

enum membership_status {
  active
  invited
  suspended
  banned
}

enum token_type {
  email_verification
  password_reset
  magic_link
  phone_verification
}

// ── MODEL: apps ───────────────────────────────────────────────

model apps {
  id                    String    @id @default(uuid()) @db.Uuid
  name                  String    @db.VarChar(100)
  slug                  String    @unique @db.VarChar(50)
  description           String?   @db.Text
  client_id             String    @unique @default(uuid())
  client_secret         String    @default(uuid())
  allowed_callback_urls Json      @default("[]")
  allowed_logout_urls   Json      @default("[]")
  allowed_origins       Json      @default("[]")
  allowed_web_origins   Json      @default("[]")
  jwt_secret            String?   @db.VarChar(255)
  access_token_ttl      Int       @default(900)
  refresh_token_ttl     Int       @default(2592000)
  settings              Json      @default("{}")
  logo_url              String?   @db.VarChar(500)
  is_active             Boolean   @default(true)
  created_at            DateTime  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at            DateTime? @db.Timestamptz(6)

  // Relations
  roles                roles[]
  permissions          permissions[]
  user_app_memberships user_app_memberships[]
  user_roles           user_roles[]
  sessions             sessions[]
  refresh_tokens       refresh_tokens[]
  oauth_states         oauth_states[]
  audit_logs           audit_logs[]

  @@index([client_id])
  @@index([slug])
}

// ── MODEL: users ──────────────────────────────────────────────

model users {
  id                String    @id @default(uuid()) @db.Uuid
  email             String?   @unique @db.Text // citext di PG, pakai Text di Prisma
  email_verified_at DateTime? @db.Timestamptz(6)
  phone             String?   @unique @db.VarChar(20)
  phone_verified_at DateTime? @db.Timestamptz(6)
  username          String?   @unique @db.Text // citext
  display_name      String?   @db.VarChar(150)
  avatar_url        String?   @db.VarChar(500)
  is_active         Boolean   @default(true)
  is_banned         Boolean   @default(false)
  ban_reason        String?   @db.Text
  banned_at         DateTime? @db.Timestamptz(6)
  banned_by         String?   @db.Uuid
  last_login_at     DateTime? @db.Timestamptz(6)
  last_login_ip     String?   @db.Text // inet → Text di Prisma
  login_count       Int       @default(0)
  locale            String    @default("en") @db.VarChar(10)
  timezone          String    @default("UTC") @db.VarChar(50)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at        DateTime? @db.Timestamptz(6)

  // Self-ref: siapa yang ban user ini
  banned_by_user users?  @relation("UserBannedBy", fields: [banned_by], references: [id])
  banned_users   users[] @relation("UserBannedBy")

  // Relations
  user_profiles            user_profiles?
  passwords                passwords?
  identities               identities[]
  user_app_memberships     user_app_memberships[]
  user_roles               user_roles[]
  user_roles_granted       user_roles[]           @relation("UserRolesGrantedBy")
  sessions                 sessions[]
  refresh_tokens           refresh_tokens[]
  verification_tokens      verification_tokens[]
  mfa_configs              mfa_configs[]
  mfa_backup_codes         mfa_backup_codes[]
  audit_logs               audit_logs[]
  role_permissions_granted role_permissions[]     @relation("RolePermissionsGrantedBy")
  oauth_states_existing    oauth_states[]         @relation("OAuthExistingUser")

  @@index([email])
  @@index([phone])
  @@index([username])
  @@index([is_active])
  @@index([created_at])
}

// ── MODEL: user_profiles ──────────────────────────────────────

model user_profiles {
  id            String    @id @default(uuid()) @db.Uuid
  user_id       String    @unique @db.Uuid
  first_name    String?   @db.VarChar(100)
  last_name     String?   @db.VarChar(100)
  bio           String?   @db.Text
  date_of_birth DateTime? @db.Date
  gender        String?   @db.VarChar(20)
  website_url   String?   @db.VarChar(500)
  location      String?   @db.VarChar(150)
  metadata      Json      @default("{}")
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// ── MODEL: passwords ──────────────────────────────────────────

model passwords {
  id              String   @id @default(uuid()) @db.Uuid
  user_id         String   @unique @db.Uuid
  password_hash   String   @db.VarChar(255)
  previous_hashes Json     @default("[]")
  must_change     Boolean  @default(false)
  changed_at      DateTime @default(now()) @db.Timestamptz(6)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// ── MODEL: identities ─────────────────────────────────────────

model identities {
  id                        String        @id @default(uuid()) @db.Uuid
  user_id                   String        @db.Uuid
  provider                  provider_type
  provider_user_id          String        @db.VarChar(255)
  provider_email            String?       @db.Text // citext
  provider_access_token     String?       @db.Text // encrypted
  provider_refresh_token    String?       @db.Text // encrypted
  provider_token_expires_at DateTime?     @db.Timestamptz(6)
  provider_data             Json          @default("{}")
  is_primary                Boolean       @default(false)
  created_at                DateTime      @default(now()) @db.Timestamptz(6)
  updated_at                DateTime      @default(now()) @updatedAt @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_user_id], name: "uq_identities_provider")
  @@index([user_id])
  @@index([provider, provider_email])
}

// ── MODEL: roles ──────────────────────────────────────────────

model roles {
  id             String   @id @default(uuid()) @db.Uuid
  app_id         String?  @db.Uuid
  name           String   @db.VarChar(100)
  slug           String   @db.VarChar(100)
  description    String?  @db.Text
  is_system      Boolean  @default(false)
  parent_role_id String?  @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Self-reference untuk role hierarchy
  parent_role roles?  @relation("RoleHierarchy", fields: [parent_role_id], references: [id])
  child_roles roles[] @relation("RoleHierarchy")

  apps             apps?              @relation(fields: [app_id], references: [id], onDelete: Cascade)
  role_permissions role_permissions[]
  user_roles       user_roles[]

  @@unique([app_id, slug], name: "uq_roles_app_slug")
  @@index([app_id])
}

// ── MODEL: permissions ────────────────────────────────────────

model permissions {
  id          String   @id @default(uuid()) @db.Uuid
  app_id      String?  @db.Uuid
  name        String   @db.VarChar(150)
  slug        String   @db.VarChar(150)
  description String?  @db.Text
  group_name  String?  @db.VarChar(100)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  apps             apps?              @relation(fields: [app_id], references: [id], onDelete: Cascade)
  role_permissions role_permissions[]

  @@unique([app_id, slug], name: "uq_permissions_app_slug")
  @@index([app_id])
  @@index([app_id, group_name])
}

// ── MODEL: role_permissions ───────────────────────────────────

model role_permissions {
  role_id       String   @db.Uuid
  permission_id String   @db.Uuid
  granted_at    DateTime @default(now()) @db.Timestamptz(6)
  granted_by    String?  @db.Uuid

  roles           roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permissions     permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  granted_by_user users?      @relation("RolePermissionsGrantedBy", fields: [granted_by], references: [id], onDelete: SetNull)

  @@id([role_id, permission_id])
}

// ── MODEL: user_app_memberships ───────────────────────────────

model user_app_memberships {
  id         String            @id @default(uuid()) @db.Uuid
  user_id    String            @db.Uuid
  app_id     String            @db.Uuid
  status     membership_status @default(active)
  invited_by String?           @db.Uuid
  joined_at  DateTime?         @db.Timestamptz(6)
  settings   Json              @default("{}")
  created_at DateTime          @default(now()) @db.Timestamptz(6)
  updated_at DateTime          @default(now()) @updatedAt @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
  apps  apps  @relation(fields: [app_id], references: [id], onDelete: Cascade)

  @@unique([user_id, app_id], name: "uq_membership_user_app")
  @@index([user_id])
  @@index([app_id])
  @@index([app_id, status])
}

// ── MODEL: user_roles ─────────────────────────────────────────

model user_roles {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  role_id    String    @db.Uuid
  app_id     String?   @db.Uuid
  granted_by String?   @db.Uuid
  expires_at DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  users           users  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  roles           roles  @relation(fields: [role_id], references: [id], onDelete: Cascade)
  apps            apps?  @relation(fields: [app_id], references: [id], onDelete: Cascade)
  granted_by_user users? @relation("UserRolesGrantedBy", fields: [granted_by], references: [id], onDelete: SetNull)

  @@unique([user_id, role_id, app_id], name: "uq_user_roles")
  @@index([user_id])
  @@index([app_id])
  @@index([expires_at])
}

// ── MODEL: sessions ───────────────────────────────────────────

model sessions {
  id             String         @id @default(uuid()) @db.Uuid
  user_id        String         @db.Uuid
  app_id         String         @db.Uuid
  status         session_status @default(active)
  device_id      String?        @db.VarChar(255)
  device_name    String?        @db.VarChar(255)
  device_type    String?        @db.VarChar(50)
  user_agent     String?        @db.Text
  ip_address     String?        @db.Text // inet → Text di Prisma
  country_code   String?        @db.Char(2)
  city           String?        @db.VarChar(100)
  last_active_at DateTime       @default(now()) @db.Timestamptz(6)
  expires_at     DateTime       @db.Timestamptz(6)
  revoked_at     DateTime?      @db.Timestamptz(6)
  revoke_reason  String?        @db.VarChar(100)
  created_at     DateTime       @default(now()) @db.Timestamptz(6)

  users          users            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  apps           apps             @relation(fields: [app_id], references: [id], onDelete: Cascade)
  refresh_tokens refresh_tokens[]

  @@index([user_id])
  @@index([app_id])
  @@index([user_id, app_id, status])
  @@index([expires_at])
}

// ── MODEL: refresh_tokens ─────────────────────────────────────

model refresh_tokens {
  id            String    @id @default(uuid()) @db.Uuid
  session_id    String    @db.Uuid
  user_id       String    @db.Uuid
  app_id        String    @db.Uuid
  token_hash    String    @unique @db.VarChar(255)
  replaced_by   String?   @db.Uuid
  family        String    @default(uuid()) @db.Uuid
  used_at       DateTime? @db.Timestamptz(6)
  expires_at    DateTime  @db.Timestamptz(6)
  revoked_at    DateTime? @db.Timestamptz(6)
  revoke_reason String?   @db.VarChar(100)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)

  sessions sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)
  users    users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  apps     apps     @relation(fields: [app_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@index([user_id])
  @@index([family])
  @@index([expires_at])
}

// ── MODEL: oauth_states ───────────────────────────────────────

model oauth_states {
  id               String        @id @default(uuid()) @db.Uuid
  state            String        @unique @db.VarChar(255)
  provider         provider_type
  app_id           String        @db.Uuid
  redirect_uri     String        @db.VarChar(500)
  code_verifier    String?       @db.VarChar(255)
  existing_user_id String?       @db.Uuid
  metadata         Json          @default("{}")
  expires_at       DateTime      @default(dbgenerated("(NOW() + INTERVAL '10 minutes')")) @db.Timestamptz(6)
  created_at       DateTime      @default(now()) @db.Timestamptz(6)

  apps          apps   @relation(fields: [app_id], references: [id], onDelete: Cascade)
  existing_user users? @relation("OAuthExistingUser", fields: [existing_user_id], references: [id], onDelete: Cascade)

  @@index([state])
  @@index([expires_at])
}

// ── MODEL: verification_tokens ────────────────────────────────

model verification_tokens {
  id                String     @id @default(uuid()) @db.Uuid
  user_id           String     @db.Uuid
  type              token_type
  token_hash        String     @unique @db.VarChar(255)
  target            String     @db.VarChar(255)
  requested_from_ip String?    @db.Text // inet → Text
  expires_at        DateTime   @db.Timestamptz(6)
  used_at           DateTime?  @db.Timestamptz(6)
  created_at        DateTime   @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, type])
  @@index([expires_at])
}

// ── MODEL: mfa_configs ────────────────────────────────────────

model mfa_configs {
  id            String    @id @default(uuid()) @db.Uuid
  user_id       String    @db.Uuid
  type          mfa_type
  secret        String?   @db.Text // encrypted
  totp_issuer   String?   @db.VarChar(100)
  credential_id String?   @db.VarChar(500)
  public_key    String?   @db.Text
  sign_count    Int?      @default(0)
  is_enabled    Boolean   @default(false)
  is_primary    Boolean   @default(false)
  verified_at   DateTime? @db.Timestamptz(6)
  device_name   String?   @db.VarChar(255)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, type, credential_id], name: "uq_mfa_user_type")
  @@index([user_id])
}

// ── MODEL: mfa_backup_codes ───────────────────────────────────

model mfa_backup_codes {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  code_hash  String    @db.VarChar(255)
  used_at    DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

// ── MODEL: audit_logs ─────────────────────────────────────────

model audit_logs {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String?  @db.Uuid
  app_id        String?  @db.Uuid
  session_id    String?  @db.Uuid // Sengaja tidak ada FK (session bisa dihapus)
  action        String   @db.VarChar(100)
  status        String   @default("success") @db.VarChar(20)
  error_message String?  @db.Text
  resource_type String?  @db.VarChar(100)
  resource_id   String?  @db.VarChar(255)
  ip_address    String?  @db.Text // inet → Text
  user_agent    String?  @db.Text
  country_code  String?  @db.Char(2)
  metadata      Json     @default("{}")
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  // Tidak ada updated_at — audit log bersifat immutable
  users users? @relation(fields: [user_id], references: [id], onDelete: SetNull)
  apps  apps?  @relation(fields: [app_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([app_id])
  @@index([action, created_at])
  @@index([resource_type, resource_id])
  @@index([created_at])
  @@index([user_id, created_at])
}
